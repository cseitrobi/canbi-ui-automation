<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console: time | thread | level | logger | message -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} | %-5level | %logger{40} | %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- File: full timestamp, same format (target/test-logs/automation.log) -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>target/test-logs/automation.log</file>
        <append>false</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} | %-5level | %logger{50} | %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <logger name="com.pilla.automation" level="INFO"/>
    <logger name="io.appium" level="WARN"/>
    <logger name="org.openqa.selenium" level="WARN"/>
    <!-- Allure lifecycle errors when test is failed/skipped are expected; reduce noise -->
    <logger name="io.qameta.allure" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
